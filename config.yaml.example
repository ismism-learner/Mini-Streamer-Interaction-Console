# 小主播互动机 配置文件示例
# 复制此文件为 config.yaml 并填入你的实际配置

SAMPLE_RATE: 16000
CHANNELS: 1
DTYPE: int16
CHUNK_DURATION_MS: 30
SILENCE_TIMEOUT_MS: 1500
MAX_RECORDING_MINUTES: 10
MIN_WORDS_FOR_QUESTION: 10
MAX_WORDS_FORCE_TRIGGER: 100
TRIGGER_PHRASES:
- 你明白了吗
- 你们懂了没有
- 听懂了吗
- 你学会了吗
- 懂了吗
- 明白了没有
DISPLAY_FONT_FAMILY: FangSong
DISPLAY_FONT_SIZE: 15
DISABLE_EMOJI: true
DISPLAY_X: -1
DISPLAY_Y: -1
DISPLAY_CHARS_PER_LINE: 13
DISPLAY_HEIGHT: 396
DISPLAY_DISAPPEAR_MODE: keep
DISPLAY_DISAPPEAR_SECONDS: 4
DISPLAY_STACK_MAX: 5
WHISPER_MODEL_SIZE: small
WHISPER_DEVICE: cpu
WHISPER_COMPUTE_TYPE: int8
LLM_API_BASE: https://api.siliconflow.cn/v1
LLM_API_KEY: your-api-key-here
LLM_MODEL: Qwen/Qwen3-8B
SERVER_HOST: 127.0.0.1
SERVER_PORT: 8765
